                    </div>
                    <p>${item.desc}</p>
                    <button class="add-to-cart-btn" onclick="addToCart(${item.id})" id="cartBtn${item.id}">
                        Add to Order
                    </button>
                </div>
            `).join('')}
        </div>
    `).join('');

    observeFadeIns();
}

function filterMenu(cat) {
    activeFilter = cat;
    renderMenu();
}


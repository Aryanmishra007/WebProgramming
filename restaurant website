function openOrderTracking() {
    const orders = DB.get('orders') || [];
    const content = document.getElementById('orderTrackingContent');

    if (orders.length === 0) {
        content.innerHTML = '<p style="color:#999;text-align:center;padding:2rem 0">No orders yet. Place an order from our menu!</p>';
    } else {
        const latest = orders[orders.length - 1];
        const steps = [
            { key: 'pending', label: 'Order Placed', desc: 'Your order has been received' },
            { key: 'confirmed', label: 'Confirmed', desc: 'Kitchen has confirmed your order' },
            { key: 'preparing', label: 'Preparing', desc: 'Chef is preparing your dishes' },
            { key: 'ready', label: 'Ready', desc: 'Your order is ready' },
            { key: 'delivered', label: 'Completed', desc: 'Enjoy your meal!' },
        ];
        const statusIdx = steps.findIndex(s => s.key === latest.status);

        content.innerHTML = `
            <p style="margin-bottom:0.5rem"><strong>Order #${latest.id}</strong> — ${latest.type} — $${latest.total.toFixed(2)}</p>
            <p style="color:#999;margin-bottom:1.5rem">${new Date(latest.createdAt).toLocaleString()}</p>
            <div class="order-status-steps">
                ${steps.map((step, i) => `
                    <div class="status-step ${i < statusIdx ? 'completed' : ''} ${i === statusIdx ? 'active' : ''}">
                        <div class="status-dot">${i < statusIdx ? '✓' : i === statusIdx ? '●' : ''}</div>
                        <div class="status-info">
                            <h4>${step.label}</h4>
                            <p>${step.desc}</p>
                        </div>
                    </div>
                `).join('')}
            </div>
            <p style="color:#999;font-size:0.9rem;margin-top:1rem">Items: ${latest.items.map(i => i.name).join(', ')}</p>
        `;
    }
    document.getElementById('orderTrackingModal').classList.add('active');
}


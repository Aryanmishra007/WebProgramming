    const total = cart.reduce((s, c) => s + c.price * c.qty, 0);

    document.getElementById('checkoutContent').innerHTML = `
        <div class="order-summary">
            ${cart.map(c => `
                <div class="order-summary-item">
                    <span>${c.name} × ${c.qty}</span>
                    <span>$${(c.price * c.qty).toFixed(2)}</span>
                </div>
            `).join('')}
            <div class="order-summary-total">
                <span>Total</span>
                <span class="price">$${total.toFixed(2)}</span>
            </div>
        </div>
        <div class="checkout-form">
            <div class="form-row">
                <div class="form-group">
                    <label>Full Name *</label>
                    <input type="text" id="checkName" required>
                </div>
                <div class="form-group">
                    <label>Phone *</label>
                    <input type="tel" id="checkPhone" required>
                </div>
            </div>
            <div class="form-group">
                <label>Email *</label>
                <input type="email" id="checkEmail" required>
            </div>
            <div class="form-group">
                <label>Order Type</label>
                <select id="checkType">
                    <option value="dine-in">Dine-in</option>
                    <option value="takeout">Takeout</option>
                </select>
            </div>
            <div class="form-group">
                <label>Special Instructions</label>
                <textarea id="checkNotes" placeholder="Any allergies or preferences..."></textarea>
            </div>
            <button class="submit-button" onclick="placeOrder()">Place Order</button>
        </div>
    `;
    document.getElementById('checkoutModal').classList.add('active');
}

function placeOrder() {
    const name = document.getElementById('checkName').value.trim();
    const phone = document.getElementById('checkPhone').value.trim();
    const email = document.getElementById('checkEmail').value.trim();
    if (!name || !phone || !email) { toast('Please fill all required fields', 'error'); return; }

    const cart = getCart();
    const total = cart.reduce((s, c) => s + c.price * c.qty, 0);
    const orderId = DB.get('nextOrderId');
    DB.set('nextOrderId', orderId + 1);

    const order = {
        id: orderId,
        name, phone, email,
        type: document.getElementById('checkType').value,
        notes: document.getElementById('checkNotes').value.trim(),
        items: [...cart],
        total,
        status: 'pending',
        createdAt: new Date().toISOString()
    };

    const orders = DB.get('orders') || [];
    orders.push(order);
    DB.set('orders', orders);
    saveCart([]);
    closeModal('checkoutModal');
    toast(`Order #${orderId} placed successfully!`, 'success');
    updateCartBadge();

    // Auto-progress order status for demo
    simulateOrderProgress(orderId);
}

function simulateOrderProgress(orderId) {
    const statuses = ['confirmed', 'preparing', 'ready', 'delivered'];
    statuses.forEach((status, i) => {
        setTimeout(() => {
            const orders = DB.get('orders') || [];
            const order = orders.find(o => o.id === orderId);
            if (order && order.status !== 'cancelled') {
                order.status = status;
                DB.set('orders', orders);
                if (status === 'confirmed') toast(`Order #${orderId} confirmed!`, 'success');
                if (status === 'ready') toast(`Order #${orderId} is ready!`, 'success');
            }
        }, (i + 1) * 8000);
    });
}


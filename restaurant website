// RESERVATIONS
// ═══════════════════════════════════════════════════════════════
const form = document.getElementById('reservationForm');
const formMessage = document.getElementById('formMessage');
const dateInput = document.getElementById('date');
dateInput.setAttribute('min', new Date().toISOString().split('T')[0]);

form.addEventListener('submit', (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const data = Object.fromEntries(fd);

    if (!/^[\d\s\-\+\(\)]+$/.test(data.phone)) { showFormMsg('Please enter a valid phone number', 'error'); return; }
    if (new Date(data.date) < new Date(new Date().toDateString())) { showFormMsg('Please select a future date', 'error'); return; }

    // Check for time conflicts (basic)
    const reservations = DB.get('reservations') || [];
    const conflict = reservations.find(r => r.date === data.date && r.time === data.time && r.status !== 'cancelled');
    if (conflict) {
        showFormMsg('That time slot is already booked. Please choose another time.', 'error');
        return;
    }

    const reservation = {
        id: generateId(),
        ...data,
        status: 'pending',
        createdAt: new Date().toISOString()
    };
    reservations.push(reservation);
    DB.set('reservations', reservations);

    showFormMsg('Reservation submitted successfully! We will confirm shortly.', 'success');
    toast('Reservation booked!', 'success');
    form.reset();
    setTimeout(() => { formMessage.style.display = 'none'; }, 4000);
});

function showFormMsg(msg, type) {
    formMessage.textContent = msg;
    formMessage.className = `form-message ${type}`;
}

